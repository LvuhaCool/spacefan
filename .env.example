# Copy to .env for local development.
# In Railway: paste these in the Variables tab (not this file).

# Generated by: npm run setup
PASSWORD_HASH=

# From console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Your email address (where OTP codes will be sent)
YOUR_EMAIL=you@gmail.com

# From resend.com → API Keys
RESEND_API_KEY=re_...

# Leave as-is for Resend sandbox (works without a custom domain)
RESEND_FROM=Spacefan <onboarding@resend.dev>

# Railway sets PORT automatically — don't add it yourself
# NODE_ENV is set to "production" by Railway automatically
